#!/usr/bin/env bash
# zellij-pane-wrapper: Runs inside each spawned zellij pane.
# Receives a synthetic pane ID as $1, registers state, then supervises a
# sequence of commands delivered over a persistent FIFO.
#
# Usage (called by the shim, not directly):
#   zellij-pane-wrapper <state_dir> <shim_dir> %N
#
# Note: args are passed explicitly because zellij new-pane does NOT
# inherit the calling shell's environment variables.
#
# Lifecycle: modern Claude Code launches an agent pane by first creating an
# idle placeholder (`split-window -- cat`) and then replacing it with the real
# command via `respawn-pane -k -t %N -- <cmd>`. To support that, the FIFO is
# kept open for the life of the pane and each command we read REPLACES the
# currently-running child (tmux respawn-pane -k semantics).

set -euo pipefail

STATE_DIR="$1"
SHIM_DIR="$2"
PANE_ID="$3"

# Restore the parent shell's environment.
# The tmux shim snapshots env via `export -p` before spawning us, because
# zellij new-pane does NOT inherit the calling process's environment (unlike tmux).
# Using eval handles the `declare -x VAR="value"` format and multiline values.
ENV_FILE="${STATE_DIR}/parent.env"
if [ -f "$ENV_FILE" ]; then
    eval "$(cat "$ENV_FILE")" 2>/dev/null || true
fi

# Override pane-specific vars (these differ per pane)
export ZELLIJ_TMUX_SHIM_STATE="$STATE_DIR"
export ZELLIJ_TMUX_SHIM_DIR="$SHIM_DIR"
export TMUX_PANE="$PANE_ID"

# Clean pane ID for filenames (strip leading %)
PANE_KEY="${PANE_ID#%}"

# Validate pane key is a non-negative integer (prevents path traversal)
case "$PANE_KEY" in
    ''|*[!0-9]*)
        echo "zellij-pane-wrapper: invalid pane ID: $PANE_ID" >&2
        exit 1
        ;;
esac

# Write zellij's actual pane ID (available as env var inside zellij panes)
echo "${ZELLIJ_PANE_ID:-unknown}" > "${STATE_DIR}/${PANE_KEY}.zellij_id"

# Write our PID so kill-pane can terminate us
echo "$$" > "${STATE_DIR}/${PANE_KEY}.pid"

# Create the named FIFO for command delivery
FIFO_PATH="${STATE_DIR}/${PANE_KEY}.fifo"
# Safety: ensure the path isn't a pre-existing symlink (TOCTOU mitigation)
if [ -L "$FIFO_PATH" ]; then
    echo "zellij-pane-wrapper: FIFO path is a symlink, aborting" >&2
    exit 1
fi
rm -f "$FIFO_PATH"
mkfifo -m 600 "$FIFO_PATH"

# Cleanup on exit: remove state files
cleanup() {
    rm -f "${STATE_DIR}/${PANE_KEY}.pid"
    rm -f "${STATE_DIR}/${PANE_KEY}.zellij_id"
    rm -f "${STATE_DIR}/${PANE_KEY}.fifo"
    rm -f "${STATE_DIR}/${PANE_KEY}.ready"
    rm -f "${STATE_DIR}/${PANE_KEY}.group"
    rm -f "${STATE_DIR}/${PANE_KEY}.named"
    rm -f "${STATE_DIR}/${PANE_KEY}.child"
}
trap cleanup EXIT

# Signal readiness — the shim's split-window handler polls for this
touch "${STATE_DIR}/${PANE_KEY}.ready"

# ---------------------------------------------------------------------------
# Command supervisor
# ---------------------------------------------------------------------------
# Open the FIFO read-write on FD 3 and hold it open for the life of the pane.
# Opening read-write never blocks on a missing writer, and keeping a writer
# reference alive means reads never hit EOF when the shim closes its end
# between commands.
exec 3<>"$FIFO_PATH" || {
    echo "zellij-pane-wrapper: failed to open command FIFO" >&2
    exit 1
}

# Save the pane's real stdin (the PTY) on FD 4. We run each command as a
# background job so this loop can keep watching the FIFO; but in a shell with
# job control off, a background job's stdin is silently reassigned to
# /dev/null. That would feed the agent (and even the `cat` placeholder)
# end-of-file instead of the keyboard, so we explicitly restore stdin from FD 4
# when launching the child.
exec 4<&0

# Relax errexit for the supervisor loop: read timeouts return non-zero,
# kill -0 on a dead PID returns non-zero, and arithmetic yielding 0 would all
# trip `set -e`. The setup above keeps its strict error handling.
set +e

CHILD=""
CHILD_FILE="${STATE_DIR}/${PANE_KEY}.child"
NAMED_FILE="${STATE_DIR}/${PANE_KEY}.named"

# Kill the current child (if any) and reap it. Used before launching a
# replacement command, mirroring `respawn-pane -k`.
kill_child() {
    if [ -n "$CHILD" ] && kill -0 "$CHILD" 2>/dev/null; then
        kill -TERM "$CHILD" 2>/dev/null
        _i=0
        while [ "$_i" -lt 20 ] && kill -0 "$CHILD" 2>/dev/null; do
            sleep 0.1 2>/dev/null || sleep 1
            _i=$((_i + 1))
        done
        kill -KILL "$CHILD" 2>/dev/null
        wait "$CHILD" 2>/dev/null
    fi
    CHILD=""
    rm -f "$CHILD_FILE"
}

# Launch a command as the pane's child process.
start_command() {
    _cmd="$1"

    # Extract the agent name and lock the pane title via zellij rename-pane.
    # The new pane still has focus here (split-window leaves it focused and the
    # subsequent respawn-pane does not move focus), so rename-pane targets it.
    # Locking the title makes Claude Code's continuous title resets no-ops.
    if [[ "$_cmd" =~ --agent-name[[:space:]]+([^[:space:]]+) ]]; then
        _agent_name="${BASH_REMATCH[1]}"
        echo "[wrapper] renaming pane to '${_agent_name}' (zellij_pane=${ZELLIJ_PANE_ID:-?})" >> "${STATE_DIR}/shim.log" 2>/dev/null || true
        zellij action rename-pane "$_agent_name" >/dev/null 2>>"${STATE_DIR}/shim.log" || true
    fi

    # Run the command in the background so this loop can keep watching the FIFO
    # for a replacement. Because job control is disabled in non-interactive
    # shells, the child stays in this wrapper's process group — the foreground
    # group of the pane's PTY — so interactive programs (claude) keep TTY
    # access. stdin is restored from FD 4 (the real PTY) so it isn't the
    # /dev/null that backgrounding would otherwise assign; FD 3 (the FIFO) and
    # FD 4 are closed for the child so it inherits neither. The command is a
    # shell-command line (serialize_command delivers it unescaped), so `eval`
    # interprets the compound `cd /path && env VAR=val /path/to/binary` that
    # Claude Code sends; we avoid exec because exec can't run a compound command.
    eval "$_cmd" <&4 3<&- 4<&- &
    CHILD=$!
    echo "$CHILD" > "$CHILD_FILE"

    # Signal that naming is done — the shim waits for this before returning.
    touch "$NAMED_FILE"
}

# Wait up to ~5 minutes for the first command before giving up (the shim may
# have crashed before delivering anything). Once a child is running we wait
# indefinitely — the agent decides its own lifetime.
IDLE=0
IDLE_LIMIT=300

while true; do
    # If a child was running but has exited on its own, and nothing new is
    # queued, the pane's work is done — exit so zellij closes the pane
    # (--close-on-exit).
    if [ -n "$CHILD" ] && ! kill -0 "$CHILD" 2>/dev/null; then
        wait "$CHILD" 2>/dev/null
        CHILD=""
        rm -f "$CHILD_FILE"
        break
    fi

    # Poll the FIFO for a (replacement) command with a 1s timeout.
    if IFS= read -r -t 1 NEW_COMMAND <&3; then
        [ -z "$NEW_COMMAND" ] && continue
        IDLE=0
        kill_child
        start_command "$NEW_COMMAND"
    else
        # read returned non-zero: >128 means timeout, anything else is an
        # unexpected EOF/error (shouldn't happen while we hold the write end).
        if [ "$?" -gt 128 ]; then
            if [ -z "$CHILD" ]; then
                IDLE=$((IDLE + 1))
                if [ "$IDLE" -ge "$IDLE_LIMIT" ]; then
                    echo "zellij-pane-wrapper: timed out waiting for command" >&2
                    break
                fi
            fi
        else
            sleep 1
        fi
    fi
done

exec 3<&- 2>/dev/null || true
